# Server
PORT=4000
BASE_URL=https://example.com
PUBLIC_PATH_PREFIX=/calendar/7shifts/birthdays
CONTACTS_PATH_PREFIX=/contacts/carddav
CONTACTS_BOOK_NAME=7shifts Staff
TIMEZONE=America/New_York
HORIZON_YEARS=10

# 7shifts API
SEVENSHIFTS_ACCESS_TOKEN=replace-with-valid-access-token
SEVENSHIFTS_API_BASE_URL=https://api.7shifts.com/v2
PRIVATE_AUTH_USERNAME=admin
PRIVATE_AUTH_PASSWORD=replace-with-strong-password

# Cache snapshot location
CACHE_FILE_PATH=./data/cache.json
